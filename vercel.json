{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "node scripts/vercel-build.mjs",
  "outputDirectory": "packages/app-client/dist",
  "functions": {
    "api/[...].ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...]"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
